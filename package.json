{
  "name": "linkedin-scraper",
  "version": "1.0.0",
  "description": "Scrape LinkedIn saved posts to Markdown files",
  "main": "dist/main.js",
  "bin": {
    "linkedin-scraper": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').copyFileSync('src/enrichment/default_system_prompt.md','dist/enrichment/default_system_prompt.md')\"",
    "start": "ts-node src/cli.ts scrape",
    "scrape": "ts-node src/cli.ts scrape",
    "auth": "ts-node src/cli.ts auth",
    "init": "ts-node src/cli.ts init",
    "summarize": "ts-node src/cli.ts summarize",
    "dev": "ts-node src/cli.ts",
    "test:parser": "ts-node -e \"const fs=require('fs');const{parsePostsFromHtml}=require('./src/parser/postParser');const html=fs.readFileSync('./references/posts-full.html','utf-8');const posts=parsePostsFromHtml(html);console.log('Posts:',posts.length);if(posts.length!==10){process.exit(1);}\"",
    "test:markdown": "ts-node test/markdownParser.test.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "linkedin",
    "scraper",
    "markdown"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.9",
    "jsdom": "^29.0.2",
    "openai": "^6.34.0",
    "picocolors": "^1.1.1",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "@types/node": "^25.6.0",
    "@types/handlebars": "^4.0.40",
    "@types/jsdom": "^28.0.1",
    "@types/sharp": "^0.31.1"
  }
}
